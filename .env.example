# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is already listed in .gitignore.

# Supabase project URL and public anon key (safe for client-side use)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (server-side only, full DB access — keep secret)
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string for migrations/tooling
SUPABASE_DB_URL=

# Supabase CLI access token (for `supabase link`, CI, etc.)
SUPABASE_ACCESS_TOKEN=

# Comma-separated list of admin user emails
ADMIN_EMAILS=

# Admin bootstrap password (dev/test only)
ADMIN_PASS=

# Public site URL, used for SEO metadata, sitemap, and robots.txt generation
NEXT_PUBLIC_SITE_URL=
